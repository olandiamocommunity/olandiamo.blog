---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags = [], ...props } = data;

const primaryTag = tags[0];
---

<li class="my-6">
  <article
    class="group rounded-3xl border bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-md"
    style="border-color: #f3e3a0;"
  >
    {primaryTag && (
      <div
        class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold"
        style="background-color: #ffd21f; color: #2a1f1a;"
      >
      <span class="text-lg leading-none">✉️</span>
<span>{primaryTag}</span>
      </div>
    )}

    <a
      href={getPostUrl(id, filePath, Astro.currentLocale)}
      class="block decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
    >
      <Heading
        transition:name={slugifyStr(title.replaceAll(".", "-"))}
        class="text-2xl font-black leading-tight sm:text-3xl"
        style="color: #2a1f1a;"
      >
        {title}
      </Heading>
    </a>

    <div class="mt-4 text-sm text-[#6b6b6b]">
      <Datetime {...props} />
    </div>

    <p class="mt-4 text-lg leading-relaxed text-[#5f5f5f]">
      {description}
    </p>

    <div class="mt-6">
      <a
        href={getPostUrl(id, filePath, Astro.currentLocale)}
        class="inline-flex items-center font-bold transition group-hover:translate-x-1"
        style="color: #f17400;"
      >
        Leggi la guida →
      </a>
    </div>
  </article>
</li>
