---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />

  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="py-16 text-center sm:py-24">
      <h1
        class="mx-auto max-w-4xl text-4xl font-black leading-tight tracking-wide uppercase sm:text-6xl"
        style="color: #b41111;"
      >
        Guide pratiche per italiani nei Paesi Bassi
      </h1>

      <div
        class="mx-auto mt-5 h-3 max-w-4xl rounded-full"
        style="background-color: #fff1b8;"
      />

      <p class="mx-auto mt-10 max-w-4xl text-xl leading-relaxed text-[#5f5f5f] sm:text-2xl">
        Casa, lavoro, burocrazia, lingua e vita quotidiana: risorse concrete
        per sentirti più orientato, più connesso e meno solo in Olanda.
      </p>

      <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="inline-flex min-w-60 items-center justify-center rounded-xl px-8 py-4 text-lg font-bold text-white transition hover:scale-[1.02]"
          style="background-color: #f17400;"
        >
          Leggi le guide
        </a>

        <a
          href={getRelativeLocaleUrl(locale, "about")}
          class="inline-flex min-w-60 items-center justify-center rounded-xl border-2 px-8 py-4 text-lg font-bold transition hover:scale-[1.02]"
          style="border-color: #b41111; color: #b41111;"
        >
          Scopri Olandiamo
          <IconArrowRight class="ms-2 inline-block" />
        </a>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-16 pb-8",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2
            class="text-4xl font-black tracking-wide"
            style="color: #b41111;"
          >
            In evidenza
          </h2>
          <ul class="mt-6">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="py-16">
          <div class="mb-8 flex items-center justify-between gap-4">
            <h2
              class="text-4xl font-black tracking-wide sm:text-5xl"
              style="color: #b41111;"
            >
              Guide recenti
            </h2>

            <a
              href={getRelativeLocaleUrl(locale, "posts")}
              class="hidden text-lg font-bold sm:inline-flex"
              style="color: #f17400;"
            >
              Vedi tutte →
            </a>
          </div>

          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }
<section class="border-t py-16 text-center" style="border-color: #ffd21f;">
      <h2
        class="mx-auto max-w-4xl text-3xl font-black leading-tight tracking-wide sm:text-5xl"
        style="color: #b41111;"
      >
        Una comunità per gli italiani in Olanda
      </h2>

      <p class="mx-auto mt-6 max-w-4xl text-lg leading-relaxed text-[#5f5f5f] sm:text-xl">
        Olandiamo aiuta gli italiani nei Paesi Bassi a sentirsi più orientati,
        più connessi e meno soli. Condividiamo guide pratiche, risorse utili e
        creiamo spazi di confronto.
      </p>

      <div class="mt-14 grid gap-10 sm:grid-cols-3">
        <div class="flex flex-col items-center">
          <div
            class="flex h-20 w-20 items-center justify-center rounded-full text-4xl text-white"
            style="background-color: #f17400;"
          >
            📍
          </div>
          <h3 class="mt-6 text-2xl font-black">Orientati</h3>
          <p class="mt-3 max-w-xs text-lg leading-relaxed text-[#5f5f5f]">
            Guide chiare su casa, lavoro, burocrazia e vita quotidiana.
          </p>
        </div>

        <div class="flex flex-col items-center">
          <div
            class="flex h-20 w-20 items-center justify-center rounded-full text-4xl text-white"
            style="background-color: #f17400;"
          >
            👥
          </div>
          <h3 class="mt-6 text-2xl font-black">Connessi</h3>
          <p class="mt-3 max-w-xs text-lg leading-relaxed text-[#5f5f5f]">
            Una community attiva di italiani che si aiutano a vicenda.
          </p>
        </div>

        <div class="flex flex-col items-center">
          <div
            class="flex h-20 w-20 items-center justify-center rounded-full text-4xl text-white"
            style="background-color: #f17400;"
          >
            ♡
          </div>
          <h3 class="mt-6 text-2xl font-black">Meno soli</h3>
          <p class="mt-3 max-w-xs text-lg leading-relaxed text-[#5f5f5f]">
            Supporto umano per affrontare le sfide dell’esperienza all’estero.
          </p>
        </div>
      </div>
    </section>
    <div class="my-8 text-center sm:hidden">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        Vedi tutte le guide
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
