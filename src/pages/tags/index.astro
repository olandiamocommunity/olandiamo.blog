---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { useTranslations } from "@/i18n";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const tagCounts = tags.map(({ tag, tagName }) => {
  const count = posts.filter(post =>
    post.data.tags?.some(postTag => postTag.toLowerCase() === tagName.toLowerCase())
  ).length;

  return {
    tag,
    tagName,
    count,
  };
});
---

<Layout title={`${t.pages.tagsTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle={t.pages.tagsTitle}
    pageDesc="Esplora le guide Olandiamo per argomento. Casa, lavoro, burocrazia, lingua e vita quotidiana: scegli il tema che ti serve e trova le risorse più utili."
  >
    <ul class="grid gap-6 sm:grid-cols-2">
      {
        tagCounts.map(({ tag, tagName, count }) => (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `tags/${tag}`)}
              class="group block rounded-3xl border bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-md"
              style="border-color: #f3e3a0;"
            >
              <div
                class="mb-5 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold"
                style="background-color: #ffd21f; color: #2a1f1a;"
              >
                <span class="text-lg leading-none">✉️</span>
                <span>Argomento</span>
              </div>

              <h2
                class="text-3xl font-black tracking-wide"
                style="color: #b41111;"
              >
                {tagName}
              </h2>

              <p class="mt-3 text-lg text-[#5f5f5f]">
                {count === 1 ? "1 guida disponibile" : `${count} guide disponibili`}
              </p>

              <div
                class="mt-6 inline-flex font-bold transition group-hover:translate-x-1"
                style="color: #f17400;"
              >
                Esplora →
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Main>

  <Footer />
</Layout>
